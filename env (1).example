# ============================================================
# PLATACO — Variables de entorno
# Copia esto en Railway → Variables de entorno
# ============================================================

# Railway lo pone automáticamente, no toques este
PORT=4000

# Tu URL de Netlify (sin barra final)
FRONTEND_URLS=https://plataco.netlify.app,https://www.plataco.netlify.app

# Railway te da esta URL automáticamente cuando añades PostgreSQL
# Tiene este formato: postgresql://postgres:xxxx@xxx.railway.app:5432/railway
DATABASE_URL=postgresql://USUARIO:PASSWORD@HOST:5432/railway

# Genera uno aleatorio: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CAMBIA_ESTO_POR_UNA_CADENA_LARGA_Y_ALEATORIA

# Stripe — obtén las claves en https://dashboard.stripe.com/apikeys
# En pruebas usa sk_test_... y pk_test_...
# En producción cambia a sk_live_... y pk_live_...
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXXX

# Stripe — obtén esto en https://dashboard.stripe.com/webhooks
# Cuando crees el endpoint webhook apuntando a:
# https://TU-BACKEND.railway.app/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXXX

NODE_ENV=production

