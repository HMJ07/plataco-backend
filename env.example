# ============================================================
# PLATACO — Variables de entorno
# IMPORTANTE: Nunca subas este archivo a GitHub
#             Añade .env a tu .gitignore
# ============================================================

# ── Servidor ────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# ── Base de datos PostgreSQL ────────────────────────────────
# Formato: postgresql://USUARIO:CONTRASEÑA@HOST:PUERTO/NOMBRE_DB
DATABASE_URL=postgresql://plataco_user:tu_contraseña@localhost:5432/plataco

# ── Seguridad JWT ───────────────────────────────────────────
# Genera un secreto aleatorio con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=aqui_pon_un_secreto_largo_y_aleatorio_de_al_menos_64_caracteres

# ── Stripe ──────────────────────────────────────────────────
# Obtén estas claves en https://dashboard.stripe.com/apikeys
# En desarrollo usa las claves de TEST (empiezan con sk_test_ y pk_test_)
# En producción cambia a las claves LIVE (sk_live_ y pk_live_)

STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXX

# Secreto para validar webhooks de Stripe
# Obtenlo en https://dashboard.stripe.com/webhooks al crear el endpoint
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXX

# ── Email (opcional, para confirmaciones de pedido) ─────────
# Opción 1 — Resend (recomendado, plan gratuito disponible)
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXX
EMAIL_FROM=pedidos@tudominio.com

# Opción 2 — SMTP genérico
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu@email.com
# SMTP_PASS=tu_contraseña_de_aplicacion

# ── Almacenamiento de imágenes (opcional) ──────────────────
# Para subir imágenes de productos usa Cloudinary o AWS S3
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
